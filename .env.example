# App
APP_ENV=production
APP_DEBUG=false
APP_NAME="Digital Market Pro"
APP_KEY="change-this-app-key"
APP_URL="https://your-domain.com"
APP_TIMEZONE="Asia/Ho_Chi_Minh"
APP_DEFAULT_LOGIN_LOCATION="Vietnam"
APP_HTTPS_ONLY=true

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=digital_market
DB_USER=your_db_user
DB_PASS=your_db_password
DB_CHARSET=utf8mb4

# Upload
UPLOAD_PATH="/var/www/zenoxdigital/public/uploads"
UPLOAD_URL="/uploads"
UPLOAD_MAX_SIZE=2097152

# Session / Security
SESSION_IDLE_TIMEOUT=1800
CSRF_TOKEN_TTL=7200

# Rate limiting
RL_LOGIN_MAX_ATTEMPTS=5
RL_LOGIN_WINDOW=300
RL_LOGIN_LOCK=600
RL_REGISTER_MAX_ATTEMPTS=5
RL_REGISTER_WINDOW=600
RL_REGISTER_LOCK=900
RL_FORGOT_MAX_ATTEMPTS=3
RL_FORGOT_WINDOW=600
RL_FORGOT_LOCK=900
RL_PROFILE_OTP_MAX_ATTEMPTS=6
RL_PROFILE_OTP_WINDOW=300
RL_PROFILE_OTP_LOCK=600
RL_PROFILE_SENSITIVE_MAX_ATTEMPTS=6
RL_PROFILE_SENSITIVE_WINDOW=600
RL_PROFILE_SENSITIVE_LOCK=900
RL_AI_CUSTOMER_MAX_ATTEMPTS=12
RL_AI_CUSTOMER_WINDOW=180
RL_AI_CUSTOMER_LOCK=180
RL_AI_ADMIN_MAX_ATTEMPTS=30
RL_AI_ADMIN_WINDOW=180
RL_AI_ADMIN_LOCK=120

# Google OAuth
GOOGLE_OAUTH_ENABLED=false
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="https://your-domain.com/auth/google/callback"

# AI Bridge
AI_ENABLED=true
AI_PROVIDER="bridge"
AI_BRIDGE_URL=""
AI_BRIDGE_KEY=""
AI_CHAT_TIMEOUT=20
AI_BRIDGE_RETRIES=1
AI_BRIDGE_ALLOW_LOCAL_FALLBACK=true
AI_CUSTOMER_SESSION_PREFIX="customer-web"
AI_ADMIN_SESSION_PREFIX="admin-dashboard"
